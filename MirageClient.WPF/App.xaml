<Application x:Class="MirageClient.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar">
    <Application.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon" ToolTipText="MIRAGE">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="TrayOpenMenuItem" Header="Open" Click="TrayOpen_Click" />
                    <Separator />
                    <MenuItem x:Name="TrayConnectMenuItem" Header="Connect" Click="TrayConnect_Click" />
                    <MenuItem x:Name="TrayDisconnectMenuItem" Header="Disconnect" Click="TrayDisconnect_Click" />
                    <Separator />
                    <MenuItem x:Name="TrayProxyModeMenuItem" Header="Proxy mode">
                        <MenuItem x:Name="TrayProxyModeOffMenuItem" Header="Clear system proxy" Tag="off" Click="TrayProxyMode_Click" />
                        <MenuItem x:Name="TrayProxyModeSystemMenuItem" Header="Auto system proxy" Tag="system" Click="TrayProxyMode_Click" />
                        <MenuItem x:Name="TrayProxyModeManualMenuItem" Header="Do not change system proxy" Tag="manual" Click="TrayProxyMode_Click" />
                        <MenuItem x:Name="TrayProxyModePacMenuItem" Header="PAC mode" Tag="pac" Click="TrayProxyMode_Click" />
                    </MenuItem>
                    <MenuItem x:Name="TrayReapplyProxyMenuItem" Header="Reapply proxy" Click="TrayReapplyProxy_Click" />
                    <Separator />
                    <MenuItem x:Name="TrayExitMenuItem" Header="Exit" Click="TrayExit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F2EE" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FCFCFB" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F6F8F7" />
        <SolidColorBrush x:Key="InkBrush" Color="#1E2730" />
        <SolidColorBrush x:Key="MutedBrush" Color="#66727C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#D9F0EE" />
        <SolidColorBrush x:Key="WarnBrush" Color="#A56700" />
        <SolidColorBrush x:Key="WarnSoftBrush" Color="#FFF1DA" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#FDE7E6" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E3E6E8" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Application.Resources>
</Application>
