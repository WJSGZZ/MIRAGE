<Window x:Class="MirageClient.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Width="1280"
        Height="860"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#F7F7F3"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="14">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Background="#16212A"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{Binding AppTitle}" FontSize="27" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="{Binding Tagline}" Margin="0,6,0,0" Foreground="#D3DDE7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel>
                    <Button Style="{StaticResource NavButtonStyle}" Click="Overview_Click" Margin="0,0,0,8">
                        <TextBlock Text="{Binding OverviewLabel}" FontSize="16" FontWeight="SemiBold" />
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Click="Profiles_Click" Margin="0,0,0,8">
                        <TextBlock Text="{Binding ProfilesLabel}" FontSize="16" FontWeight="SemiBold" />
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Click="Diagnostics_Click" Margin="0,0,0,8">
                        <TextBlock Text="{Binding DiagnosticsLabel}" FontSize="16" FontWeight="SemiBold" />
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Click="Settings_Click">
                        <TextBlock Text="{Binding SettingsLabel}" FontSize="16" FontWeight="SemiBold" />
                    </Button>
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="0,14,0,0"
                        Background="#EDF3F2"
                        BorderBrush="#D6E7E5"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="{Binding CaptureGap}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ImportHint}" Margin="0,10,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding OverviewTitle}" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="{Binding OverviewDescription}" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Border Margin="0,0,12,0"
                                Padding="14,9"
                                CornerRadius="999"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                Background="White">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding RefreshLabel}" Click="Refresh_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid x:Name="OverviewPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="2">
                        <Border Margin="0,0,7,0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentProfileLabel}" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding ActiveProfileName}" Margin="0,10,0,0" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HttpLabel}" Margin="0,18,0,0" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding HttpProxy}" Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SocksLabel}" Margin="0,14,0,0" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding Socks5Proxy}" Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Margin="7,0,0,0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding SystemPolicyLabel}" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding CurrentProxyModeText}" Margin="0,10,0,0" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProxyAppliedLabel}" Margin="0,18,0,0" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding ProxyAppliedText}" Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding LastProxyApplyLabel}" Margin="0,14,0,0" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding ProxyApplyStatus}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Grid.Row="2" Columns="3">
                        <Border Margin="0,0,9,0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding WinHttpStateLabel}" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding WinHttpStatus}" Margin="0,10,0,0" FontSize="19" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,9,0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding EnvStateLabel}" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding EnvStatus}" Margin="0,10,0,0" FontSize="19" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding PacStateLabel}" Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding PacStatus}" Margin="0,10,0,0" FontSize="19" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding TrafficSummaryLabel}" FontSize="18" FontWeight="SemiBold" />
                                <UniformGrid Columns="3" Margin="0,18,0,0">
                                    <Border Margin="0,0,8,0" Padding="14" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Text="{Binding UploadLabel}" Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock Text="{Binding Upload}" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,8,0" Padding="14" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DownloadLabel}" Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock Text="{Binding Download}" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Padding="14" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Text="{Binding RateLabel}" Foreground="{StaticResource MutedBrush}" />
                                            <TextBlock Text="{Binding Rate}" Margin="0,8,0,0" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="{Binding QuickImportLabel}" FontSize="18" FontWeight="SemiBold" />
                                <TextBox Margin="0,16,0,0" Text="{Binding ImportUri, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding ImportLabel}" Click="Import_Click" />
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Content="{Binding OpenProfilesLabel}" Click="Profiles_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Border x:Name="ProfilesPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding ProfilesTitle}" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="{Binding ProfilesDescription}" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>

                        <TextBox Grid.Row="2" Text="{Binding ImportUri, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding ImportLabel}" Click="Import_Click" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Content="{Binding RefreshLabel}" Click="Refresh_Click" />
                        </StackPanel>

                        <Grid Grid.Row="4">
                            <TextBlock Text="{Binding NoProfilesText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Profiles.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ListView ItemsSource="{Binding Profiles}" BorderThickness="0" Background="Transparent">
                                <ListView.Style>
                                    <Style TargetType="ListView">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Profiles.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.Style>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Width="120"
                                                        Margin="14,0,0,0"
                                                        Click="ProfileToggle_Click"
                                                        Tag="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                            <Setter Property="Content" Value="{Binding DataContext.ConnectLabel, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Active}" Value="True">
                                                                    <Setter Property="Content" Value="{Binding DataContext.DisconnectLabel, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                    <Setter Property="Background" Value="{StaticResource WarnBrush}" />
                                                                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Server}" Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" />
                                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}">
                                                        <Run Text="SNI: " />
                                                        <Run Text="{Binding Sni}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="DiagnosticsPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding DiagnosticsTitle}" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="{Binding DiagnosticsDescription}" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>

                        <UniformGrid Grid.Row="2" Columns="4">
                            <Border Margin="0,0,8,0" Padding="16" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding CoreVersionLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding CoreVersion}" Margin="0,8,0,0" FontSize="17" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,8,0" Padding="16" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding ProtocolVersionLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding ProtocolVersion}" Margin="0,8,0,0" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,8,0" Padding="16" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding HealthLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding HealthText}" Margin="0,8,0,0" FontSize="17" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Background="{StaticResource PanelAltBrush}" CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding ProxyModeLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding CurrentProxyModeText}" Margin="0,8,0,0" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="150" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding DiagnosticsReportLabel}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DiagnosticsTargetHint}" Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="{Binding RefreshLabel}" Click="RefreshDiagnostics_Click" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Content="{Binding CopyDiagnosticsLabel}" Click="CopyDiagnostics_Click" />
                                </StackPanel>
                            </Grid>

                            <TextBox Grid.Row="2"
                                     Text="{Binding DiagnosticsReport, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas"
                                     FontSize="13" />

                            <Border Grid.Row="4" Background="#182229" CornerRadius="16" Padding="14">
                                <Grid>
                                    <TextBlock Text="{Binding LogEmptyText}"
                                               Foreground="#D8E2EA"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Logs.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Logs}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Logs.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="#D8E2EA" FontFamily="Consolas" Margin="0,0,0,4" TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="SettingsPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding SettingsTitle}" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="{Binding SettingsDescription}" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="{Binding LanguageLabel}" FontSize="18" FontWeight="SemiBold" />
                                        <ComboBox Margin="0,12,0,0"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  SelectedValue="{Binding SelectedLanguageMode, Mode=TwoWay}"
                                                  SelectionChanged="Language_Changed"
                                                  ItemsSource="{Binding LanguageModes}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TrayBehaviorLabel}" FontSize="18" FontWeight="SemiBold" />
                                        <CheckBox Margin="0,14,0,0"
                                                  Content="{Binding CloseToTrayLabel}"
                                                  IsChecked="{Binding CloseToTray, Mode=TwoWay}" />
                                        <CheckBox Margin="0,10,0,0"
                                                  Content="{Binding MinimizeToTrayLabel}"
                                                  IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" />
                                        <CheckBox Margin="0,10,0,0"
                                                  Content="{Binding StartMinimizedToTrayLabel}"
                                                  IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="{Binding SystemPolicyLabel}" FontSize="18" FontWeight="SemiBold" />
                                    <ComboBox Margin="0,12,0,0"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="Label"
                                              SelectedValue="{Binding SelectedProxyMode, Mode=TwoWay}"
                                              ItemsSource="{Binding ProxyModes}" />
                                    <CheckBox Margin="0,14,0,0"
                                              Content="{Binding ApplyWinHttpLabel}"
                                              IsChecked="{Binding ApplyWinHttp, Mode=TwoWay}" />
                                    <CheckBox Margin="0,10,0,0"
                                              Content="{Binding ExportEnvLabel}"
                                              IsChecked="{Binding ExportEnv, Mode=TwoWay}" />
                                    <TextBlock Margin="0,16,0,0" Text="{Binding PacAddressLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBox Margin="0,8,0,0" Text="{Binding PacUrl, Mode=OneWay}" IsReadOnly="True" />
                                    <TextBlock Margin="0,16,0,0" Text="{Binding ProxyAppliedLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding ProxyAppliedText}" FontWeight="SemiBold" />
                                    <TextBlock Margin="0,16,0,0" Text="{Binding LastProxyApplyLabel}" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Margin="0,8,0,0" Text="{Binding ProxyApplyStatus}" TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="{Binding ApplyProxyLabel}" Click="ApplyProxy_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Content="{Binding ReapplyProxyLabel}" Click="ReapplyProxy_Click" />
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Content="{Binding OpenPacLabel}" Click="OpenPac_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
